<!DOCTYPE html>
<html lang="ko">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>지출입력</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/main.css" rel="stylesheet">
</head>

<body>
    <%- include('nav.ejs') %>

        <div class="container mt-5" style="max-width: 600px;">
            <h2 class="mb-4 text-center">지출 내역 입력</h2>

            <form id="expenseForm">
                <div
                    class="mb-4 d-flex align-items-center justify-content-between p-3 rounded-3 bg-white shadow-sm border border-light">
                    <div>
                        <label class="form-check-label fw-bold text-dark d-block mb-1" for="isFixedExpense">
                            정기 고정비 등록
                        </label>
                        <small class="text-muted" style="font-size: 13px;">숨만 쉬어도 나가는 돈(월세, 보험료 등)인가요?</small>
                    </div>

                    <div class="form-check form-switch m-0 p-0 d-flex align-items-center">
                        <input class="form-check-input custom-switch" type="checkbox" role="switch" id="isFixedExpense"
                            name="isFixed">
                    </div>
                </div>
                <div class="input-group mb-3">
                    <label class="input-group-text" for="group">그룹/이벤트</label>
                    <select class="form-select" id="group" name="event">
                        <option selected disabled>선택하세요...</option>
                        <option value="개인지출">개인지출 (기본)</option>
                        <option value="여행경비">여행 경비</option>
                        <option value="모임비용">모임 비용</option>
                        <option value="경조사">경조사</option>
                        <option value="기타이벤트">기타 이벤트</option>
                    </select>
                </div>

                <div class="input-group mb-3">
                    <label class="input-group-text" for="category">카테고리</label>
                    <select class="form-select" id="category" name="category">
                        <option selected disabled>선택하세요...</option>
                        <option value="식비">식비</option>
                        <option value="교통비">교통비</option>
                        <option value="주거/통신">주거/통신</option>
                        <option value="문화/여가">문화/여가</option>
                        <option value="구독비">구독비</option>
                        <option value="쇼핑비">쇼핑비</option>
                        <option value="쇼핑비">병원비</option>
                        <option value="기타">기타</option>
                    </select>
                </div>

                <div class="input-group mb-3">
                    <span class="input-group-text">지출액</span>
                    <input type="number" class="form-control" id="amount" name="price" placeholder="금액을 입력하세요"
                        aria-label="Amount">
                    <span class="input-group-text">원</span>
                </div>

                <div class="input-group mb-3" id="dateGroup">
                    <span class="input-group-text">날짜</span>
                    <input type="date" class="form-control" id="date" name="date">
                </div>

                <div class="input-group mb-3 d-none" id="fixedCycleGroup">
                    <label class="input-group-text" for="fixedCycle">정기 주기</label>
                    <select class="form-select" id="fixedCycle" name="fixedCycle">
                        <option selected disabled>선택하세요...</option>
                        <option value="매월">매월</option>
                        <option value="매주">매주</option>
                    </select>
                </div>

                <div class="input-group mb-3 d-none" id="fixedDayGroup">
                    <label class="input-group-text" id="fixedDayLabel" for="fixedDayNumber">일자/요일</label>
                    <input type="number" class="form-control" id="fixedDayNumber" name="fixedDayOrWeek" min="1" max="31"
                        placeholder="1부터 31까지 숫자를 입력하세요">
                    <select class="form-select d-none" id="fixedWeekdaySelect" name="fixedDayOrWeek" disabled>
                        <option selected disabled>요일을 선택하세요...</option>
                        <option value="월요일">월요일</option>
                        <option value="화요일">화요일</option>
                        <option value="수요일">수요일</option>
                        <option value="목요일">목요일</option>
                        <option value="금요일">금요일</option>
                        <option value="토요일">토요일</option>
                        <option value="일요일">일요일</option>
                    </select>
                </div>

                <div class="input-group mb-4">
                    <span class="input-group-text">설명</span>
                    <input type="text" class="form-control" id="description" name="explanation"
                        placeholder="지출 관련 메모를 적어주세요">
                </div>

                <div class="d-grid gap-2">
                    <button class="btn btn-primary btn-lg" type="submit">지출 내역 저장하기</button>
                </div>

            </form>
        </div>

        <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
       <script>
    const isFixedCheckbox = document.getElementById('isFixedExpense');
    const dateGroup = document.getElementById('dateGroup');
    const fixedCycleGroup = document.getElementById('fixedCycleGroup');
    const fixedDayGroup = document.getElementById('fixedDayGroup');
    const fixedCycleSelect = document.getElementById('fixedCycle');
    const fixedDayNumberInput = document.getElementById('fixedDayNumber');
    const fixedWeekdaySelect = document.getElementById('fixedWeekdaySelect');
    const fixedDayLabel = document.getElementById('fixedDayLabel');

    function updateFixedSection() {
        const isFixed = isFixedCheckbox.checked;
        dateGroup.classList.toggle('d-none', isFixed);
        fixedCycleGroup.classList.toggle('d-none', !isFixed);
        fixedDayGroup.classList.toggle('d-none', !isFixed);

        if (!isFixed) {
            fixedCycleSelect.value = '';
            fixedDayNumberInput.value = '';
            fixedWeekdaySelect.value = '';
            fixedDayLabel.textContent = '일자/요일';
            fixedDayNumberInput.classList.remove('d-none');
            fixedDayNumberInput.disabled = true;
            fixedWeekdaySelect.classList.add('d-none');
            fixedWeekdaySelect.disabled = true;
            fixedDayNumberInput.placeholder = '주기를 먼저 선택하세요';
        } else {
            updateFixedDayField();
        }
    }

    function updateFixedDayField() {
        if (fixedCycleSelect.value === '매월') {
            fixedDayLabel.textContent = '일자';
            fixedDayNumberInput.classList.remove('d-none');
            fixedDayNumberInput.disabled = false;
            fixedWeekdaySelect.classList.add('d-none');
            fixedWeekdaySelect.disabled = true;
            fixedDayNumberInput.placeholder = '1부터 31까지 숫자를 입력하세요';
        } else if (fixedCycleSelect.value === '매주') {
            fixedDayLabel.textContent = '요일';
            fixedDayNumberInput.classList.add('d-none');
            fixedDayNumberInput.disabled = true;
            fixedWeekdaySelect.classList.remove('d-none');
            fixedWeekdaySelect.disabled = false;
        } else {
            fixedDayLabel.textContent = '일자/요일';
            fixedDayNumberInput.classList.remove('d-none');
            fixedDayNumberInput.disabled = true;
            fixedWeekdaySelect.classList.add('d-none');
            fixedWeekdaySelect.disabled = true;
            fixedDayNumberInput.placeholder = '주기를 먼저 선택하세요';
        }
    }

    isFixedCheckbox.addEventListener('change', updateFixedSection);
    fixedCycleSelect.addEventListener('change', updateFixedDayField);
    document.addEventListener('DOMContentLoaded', updateFixedSection);

    // 폼 제출 비동기 처리 수정본
    document.getElementById('expenseForm').addEventListener('submit', async (e) => {
        e.preventDefault(); 

        // [수정] HTML 내부의 실제 id를 매칭하여 데이터를 정확히 수집합니다.
        const isFixed = isFixedCheckbox.checked;
        
        // 매월이면 숫자 일자, 매주면 요일 선택 값을 가져옵니다.
        let fixedDayOrWeek = '';
        if (isFixed) {
            fixedDayOrWeek = fixedCycleSelect.value === '매월' 
                ? fixedDayNumberInput.value 
                : fixedWeekdaySelect.value;
        }

        const formData = {
            isFixed: isFixed ? 'on' : 'off',
            event: document.getElementById('group').value, // HTML에 id="group"으로 되어있음
            category: document.getElementById('category').value,
            price: document.getElementById('amount').value, // HTML에 id="amount"로 되어있음
            date: document.getElementById('date').value,
            fixedCycle: fixedCycleSelect.value,
            fixedDayOrWeek: fixedDayOrWeek,
            explanation: document.getElementById('description').value // HTML에 id="description"으로 되어있음
        };

        try {
            // [주의] '/your-route-path' 대신 실제 Node.js 서버의 라우터 주소를 입력해야 합니다.
            const response = await fetch('/expense/post', {
                method: 'POST',
                headers: { 'Content-Type': 'application/json' },
                body: JSON.stringify(formData)
            });

            const result = await response.json(); 

            if (!result.success) {
                // [수정] 백엔드에서 보낸 errors 객체 중 첫 번째 에러 메시지를 꺼내서 보여줍니다.
                const errorMessages = Object.values(result.errors);
                if (errorMessages.length > 0) {
                    alert(errorMessages[0]);
                } else {
                    alert(result.message || '유효성 검사에 실패했습니다.');
                }
            } else {
                alert('지출 내역이 성공적으로 저장되었습니다.');
                window.location.href = '/expense/list';
            }
        } catch (error) {
            console.error('서버 통신 에러:', error);
            alert('서버와 연결할 수 없습니다.');
        }
    });
</script>
</body>

</html>