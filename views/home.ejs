<!DOCTYPE html>
<html lang="ko">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>가계부 홈</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="/main.css" rel="stylesheet">
</head>
<body class="bg-light">

    <!-- 상단 바 불러오기 -->
    <%- include('nav.ejs') %>

    <!-- 💡 mx-auto를 주어 언제나 화면 정중앙에 오도록 설정 -->
    <div class="container custom-container mt-5 mx-auto">
        
        <!-- 당근마켓 카드 메뉴판 (8개 칸) -->
        <div class="row row-cols-2 row-cols-md-3 g-3">
            
            <!-- 1. 가계부 작성 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm" onclick="location.href='/expense/write'">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #fff3eb; color: #ff7e36;">✏️</div>
                        <div class="menu-title fw-bold text-dark mt-3">가계부 작성</div>
                    </div>
                </div>
            </div>

            <!-- 2. 내역 보기 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm" onclick="location.href='/expense/list'">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #e8f5e9; color: #2e7d32;">📋</div>
                        <div class="menu-title fw-bold text-dark mt-3">내역 보기</div>
                    </div>
                </div>
            </div>

            <!-- 3. 고정 지출 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm" onclick="location.href='/expense/fixedCost/list'">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #e3f2fd; color: #1565c0;">🔄</div>
                        <div class="menu-title fw-bold text-dark mt-3">고정 지출</div>
                    </div>
                </div>
            </div>

          

            <!-- 5. 통계/분석 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm" onclick="location.href='/stat'">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #f3e5f5; color: #6a1b9a;">📊</div>
                        <div class="menu-title fw-bold text-dark mt-3">통계 및 분석</div>
                    </div>
                </div>
            </div>

            <!-- 6. 자산 관리 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #e0f2f1; color: #00695c;">💳</div>
                        <div class="menu-title fw-bold text-dark mt-3">자산 관리</div>
                    </div>
                </div>
            </div>

            <!-- 7. 정기 리포트 -->
            <div class="col">
                <div class="card h-100 menu-card border-0 shadow-sm">
                    <div class="card-body text-center p-4">
                        <div class="menu-icon" style="background-color: #efebe9; color: #4e342e;">📅</div>
                        <div class="menu-title fw-bold text-dark mt-3">정기 리포트</div>
                    </div>
                </div>
            </div>

           
        </div>
    </div>

    <style>
        /* 💡 768px 이상이든 이하든 무조건 가로 900px 한도 내에서 가운데 정렬 고정 */
        
    </style>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
</body>
</html>